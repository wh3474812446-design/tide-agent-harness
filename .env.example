# Copy this file to .env, then fill in your real values.
# (一键安装器会自动生成 .env 并清空 API Key，首次在网页里填写即可。)

# 模型供应商：当前仅启用 DeepSeek。
HARNESS_MODEL_PROVIDER=deepseek

# DeepSeek（官方 OpenAI 兼容地址 https://api.deepseek.com）。
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 可选：从 JSON 配置文件加载 HTTP API 工具。
HARNESS_API_TOOLS=examples/api-tools.example.json

# 可选：MCP 服务器配置文件（兼容 Claude/Cursor 的 mcp.json 格式）。
# 不设则自动探测项目根目录的 mcp.json。参考 examples/mcp.example.json。
# MCP 服务器的工具会被桥接成 mcp__<server>__<tool>。
HARNESS_MCP_CONFIG=examples/mcp.example.json

# 可选：技能目录（每个子文件夹含一个 SKILL.md）。默认 <项目根>/skills。
# 用 install_skill 工具或 `npm run chat -- --install-skill <目录或gitURL>` 安装技能。
HARNESS_SKILLS_DIR=skills

# 工具风险权限：read 读取 / write 写入 / network 联网 / execute 执行命令。
# 注意：MCP 写类工具默认 execute，install_skill 也是 execute，需在此放行才能用。
HARNESS_ALLOW_RISKS=read,write,network,execute

# run_command 单条命令超时（毫秒）。默认 600000=10 分钟；设为 0 表示不限时（npm install / 大克隆建议）。
HARNESS_COMMAND_TIMEOUT_MS=600000
# run_command 输出字节上限，默认 10MB。
HARNESS_COMMAND_MAX_BUFFER=10485760

# 文件工具工作区根目录（不设则用启动目录）。指向你的主目录可访问整个用户目录。
# HARNESS_WORKSPACE=C:\Users\你的用户名
# 放开整机访问：允许用绝对路径在电脑任意位置读写（高风险；需要时再取消注释）。
# HARNESS_FS_UNRESTRICTED=1

# 单次对话的最大轮数 / 最大工具调用数（开放任务可调高；达到上限会优雅收尾而非报错）。
HARNESS_MAX_TURNS=12
HARNESS_MAX_TOOL_CALLS=30

# 可选：自动化 Hooks 配置（PreToolUse 可拦截工具、PostToolUse 如改完自动 lint）。
# 不设则自动探测项目根目录的 hooks.json。参考 examples/hooks.example.json。
# HARNESS_HOOKS_CONFIG=hooks.json

# examples/api-tools.example.json 用到的示例 Key。
EXAMPLE_API_KEY=your-example-service-key
